# Divisa: el panel muestra euros usando el tipo diario del BCE (app/fx.py). Este
# valor solo se usa mientras no haya cotización descargada (arranque sin red).
USD_TO_EUR_FALLBACK=0.92
# FX_AUTO_REFRESH=false desactiva la descarga (entornos sin salida a internet).
