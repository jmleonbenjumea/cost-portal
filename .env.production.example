# ==========================================================================
# Plantilla del .env de PRODUCCIÓN de cost-portal (Docker en servidor Plesk).
# Copia a `.env` EN EL SERVIDOR, rellena valores reales y haz chmod 600 .env.
# ==========================================================================

# === BASE DE DATOS (la Postgres CENTRAL compartida) ===
# Mismo Postgres que siniestros-automation y agente-clasificador-correos. Este contenedor
# se une a la red Docker de siniestros (ver docker-compose.prod.yml) y alcanza Postgres por
# el nombre de su servicio, `db:5432`. Usuario/clave = los de esa BD (la MISMA
# POSTGRES_PASSWORD del .env de siniestros).
# NO uses host.docker.internal: la BD se publica solo en el loopback del host y desde un
# contenedor esa ruta no llega.
DATABASE_URL=postgresql+asyncpg://benjumea:CAMBIA_ESTA_PASSWORD_FUERTE@db:5432/benjumea

# === PANEL ===
PORTAL_PORT=8001
ENVIRONMENT=production

# Credenciales HTTP Basic del panel. Con SSO activado quedan como acceso break-glass.
# OBLIGATORIO en producción (débil/por defecto → la app no arranca). Generar: openssl rand -hex 24
PORTAL_USER=admin
PORTAL_PASSWORD=CAMBIA_ESTA_PASSWORD_DEL_PANEL

# === SSO con Microsoft Entra ID (opt-in) ===
# Si PORTAL_SSO_ENABLED=true, el panel pide login con Microsoft restringido al tenant +
# un grupo de seguridad; el HTTP Basic de arriba queda como acceso break-glass. Reutiliza
# el MISMO App Registration de correo que siniestros-automation (MS_CLIENT_ID/SECRET/TENANT).
# Requiere registrar el Redirect URI .../auth/callback y emitir el claim de grupos (Group ID)
# en ese App Registration. Si falta cualquiera de estas variables, la app NO arranca (fail-fast).
PORTAL_SSO_ENABLED=false
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
PORTAL_REDIRECT_URI=https://costes.segurosbenjumea.com/auth/callback
# Object ID del grupo de seguridad de Entra cuyos miembros pueden acceder al panel.
PORTAL_ALLOWED_GROUP_ID=
# Secreto para firmar la cookie de sesión. Generar: openssl rand -hex 32
SESSION_SECRET=
